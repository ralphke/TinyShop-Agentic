{
  "EmbeddingService": {
    "Endpoint": "http://embeddings/embed"
  },
  "ConnectionStrings": {
    "TinyShopDB": "Server=sqlserver,1433;Database=TinyShopDB;User Id=TinyShopUser;Password=${TinyShopUser_PASSWORD};TrustServerCertificate=True;Encrypt=False;"
  },
  "AgentAccess": {
    "RequestsPerMinute": 60,
    "Agents": [
      {
        "AgentId": "copilot-shopping-agent",
        "ApiKey": "dev-change-me",
        "DisplayName": "Copilot Shopping Agent"
      },
      {
        "AgentId": "local-agent-gateway",
        "ApiKey": "dev-change-me",
        "DisplayName": "TinyShop Local Agent Gateway"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}

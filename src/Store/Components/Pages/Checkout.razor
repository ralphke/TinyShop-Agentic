@page "/cart"
@page "/checkout"
@rendermode InteractiveServer
@using DataEntities
@inject NavigationManager NavigationManager
@inject Store.Services.CartService CartService
@inject Store.Services.CustomerSessionService CustomerSession
@inject Store.Services.IShopApiService ShopApiService
@implements IDisposable

<PageTitle>Cart - TinyShop</PageTitle>

<div class="cart-shell">
    <div class="cart-header">
        <div>
            <h1>Your cart</h1>
            <p class="text-muted mb-0">Adjust quantities, remove items, and place your order once you are registered.</p>
        </div>
        <a href="/products" class="btn btn-outline-primary">Continue shopping</a>
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="cart-grid">
        <section class="cart-card">
            @if (!CartService.GetItems().Any())
            {
                <div class="alert alert-warning mb-0">Your cart is empty. <a href="/products">Go back to shopping</a>.</div>
            }
            else
            {
                @foreach (var item in CartService.GetItems())
                {
                    <div class="cart-line">
                        <div class="cart-line-copy">
                            <h2>@item.Product.Name</h2>
                            <p>@item.Product.Description</p>
                            <span class="line-price">@item.Product.Price.ToString("C") each</span>
                        </div>

                        <div class="cart-line-actions">
                            <div class="quantity-controls">
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => DecreaseQuantity(item.Product.Id)" disabled="@isBusy">-</button>
                                <span class="quantity-value">@item.Quantity</span>
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => IncreaseQuantity(item.Product)" disabled="@isBusy">+</button>
                            </div>
                            <strong>@((item.Product.Price * item.Quantity).ToString("C"))</strong>
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveItem(item.Product.Id)" disabled="@isBusy">Remove item</button>
                        </div>
                    </div>
                }
            }
        </section>

        <aside class="cart-card summary-card">
            <h2>Order summary</h2>
            <div class="summary-row">
                <span>Items</span>
                <strong>@CartService.GetItemCount()</strong>
            </div>
            <div class="summary-row total-row">
                <span>Total</span>
                <strong>@CartService.GetTotal().ToString("C")</strong>
            </div>

            @if (CustomerSession.CurrentCustomer is null)
            {
                <div class="alert alert-info mt-3 mb-3">You need to have registered to place an order.</div>
                <a href="/register" class="btn btn-primary w-100">Register or Sign In</a>
            }
            else
            {
                <div class="customer-summary">
                    <h3>Registered customer</h3>
                    <p class="mb-1"><strong>@CustomerSession.CurrentCustomer.Name</strong></p>
                    <p class="mb-1">@CustomerSession.CurrentCustomer.Email</p>
                    <p class="mb-0">@CustomerSession.CurrentCustomer.Address</p>
                </div>

                <div class="summary-actions">
                    <a href="/register" class="btn btn-outline-primary">Edit details</a>
                    <button type="button" class="btn btn-success" @onclick="PlaceOrderAsync" disabled="@(!CanPlaceOrder)">Place order</button>
                </div>
            }

            @if (CartService.GetItems().Any())
            {
                <button type="button" class="btn btn-outline-danger w-100 mt-3" @onclick="ClearCart" disabled="@isBusy">Clear cart</button>
            }
        </aside>
    </div>
</div>

@code {
    private bool isBusy;
    private string? errorMessage;

    private bool CanPlaceOrder => !isBusy && CartService.GetItems().Any() && CustomerSession.CurrentCustomer is not null;

    protected override void OnInitialized()
    {
        CartService.OnChange += HandleStateChanged;
        CustomerSession.OnChange += HandleStateChanged;
    }

    private void IncreaseQuantity(Product product)
    {
        CartService.AddItem(product);
    }

    private void DecreaseQuantity(int productId)
    {
        CartService.RemoveItem(productId);
    }

    private void RemoveItem(int productId)
    {
        CartService.RemoveAll(productId);
    }

    private void ClearCart()
    {
        CartService.Clear();
    }

    private async Task PlaceOrderAsync()
    {
        if (CustomerSession.CurrentCustomer is null || !CartService.GetItems().Any())
        {
            return;
        }

        isBusy = true;
        errorMessage = null;

        try
        {
            var order = await ShopApiService.PlaceOrderAsync(CustomerSession.CurrentCustomer.Id, CartService.GetItems());
            CartService.Clear();
            NavigationManager.NavigateTo($"/order-confirmation?orderId={order.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleStateChanged;
        CustomerSession.OnChange -= HandleStateChanged;
    }
}

@using Store.Services
@inject CartService CartService
@inject CustomerSessionService CustomerSession
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TinyShop</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Products
            </NavLink>
        </div>

        @if (CustomerSession.CurrentCustomer is null)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Register
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-door-closed" aria-hidden="true"></span> Sign In
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="bi bi-person-fill" aria-hidden="true"></span> Account
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="order-history">
                    <span class="bi bi-receipt" aria-hidden="true"></span> Order History
                </NavLink>
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cart">
                <span class="bi bi-cart-fill" aria-hidden="true"></span> Cart
                @if (CartService.GetItemCount() > 0)
                {
                    <span class="cart-badge">@CartService.GetItemCount()</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="impressum">
                <span class="bi bi-info-circle-fill" aria-hidden="true"></span> Impressum
            </NavLink>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        CustomerSession.OnChange += StateHasChanged;
        CartService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CustomerSession.OnChange -= StateHasChanged;
        CartService.OnChange -= StateHasChanged;
    }
}

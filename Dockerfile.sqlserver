FROM mcr.microsoft.com/mssql/server:2025-latest

USER root

# Install required dependencies (including unzip early)
RUN apt-get update && \
    apt-get install -y \
    curl \
    wget \
    unzip \
    apt-transport-https \
    ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Download and install .NET 8.0 SDK
RUN wget https://dot.net/v1/dotnet-install.sh -O dotnet-install.sh && \
    chmod +x dotnet-install.sh && \
    ./dotnet-install.sh --channel 8.0 --install-dir /usr/local/dotnet && \
    rm dotnet-install.sh && \
    ln -s /usr/local/dotnet/dotnet /usr/local/bin/dotnet

# Download and install sqlpackage standalone
RUN mkdir -p /opt/sqlpackage && \
    curl -L https://aka.ms/sqlpackage-linux -o /tmp/sqlpackage.zip && \
    unzip -q /tmp/sqlpackage.zip -d /opt/sqlpackage && \
    rm /tmp/sqlpackage.zip && \
    chmod +x /opt/sqlpackage/sqlpackage && \
    ln -s /opt/sqlpackage/sqlpackage /usr/local/bin/sqlpackage

# Verify installations
RUN dotnet --version && \
    sqlpackage /Version

# Create mount point for SQL init scripts
RUN mkdir -p /usr/src/sql/init

# Switch back to mssql user
USER mssql

# Keep original entrypoint
ENTRYPOINT ["/opt/mssql/bin/sqlservr"]
